{
    "version": 2,
    "cleanUrls": true,
    "functions": {
        "api/**/*.php": {
            "runtime": "vercel-php@0.7.1"
        }
    },
    "routes": [
        {
            "src": "/assets/(.*)",
            "dest": "/assets/$1"
        },
        {
            "src": "/admin",
            "status": 308,
            "headers": {
                "Location": "/admin/"
            }
        },
        {
            "src": "/admin/",
            "dest": "/api/admin/index.php"
        },
        {
            "src": "/admin/(.*).php",
            "dest": "/api/admin/$1.php"
        },
        {
            "src": "/admin/(.*)",
            "dest": "/api/admin/$1.php"
        },
        {
            "src": "/peminjam",
            "status": 308,
            "headers": {
                "Location": "/peminjam/"
            }
        },
        {
            "src": "/peminjam/",
            "dest": "/api/peminjam/index.php"
        },
        {
            "src": "/peminjam/(.*).php",
            "dest": "/api/peminjam/$1.php"
        },
        {
            "src": "/peminjam/(.*)",
            "dest": "/api/peminjam/$1.php"
        },
        {
            "src": "/petugas",
            "status": 308,
            "headers": {
                "Location": "/petugas/"
            }
        },
        {
            "src": "/petugas/",
            "dest": "/api/petugas/index.php"
        },
        {
            "src": "/petugas/(.*).php",
            "dest": "/api/petugas/$1.php"
        },
        {
            "src": "/petugas/(.*)",
            "dest": "/api/petugas/$1.php"
        },
        {
            "src": "/login.php",
            "dest": "/api/login.php"
        },
        {
            "src": "/login",
            "dest": "/api/login.php"
        },
        {
            "src": "/logout.php",
            "dest": "/api/logout.php"
        },
        {
            "src": "/logout",
            "dest": "/api/logout.php"
        },
        {
            "src": "/index.php",
            "dest": "/api/index.php"
        },
        {
            "src": "/",
            "dest": "/api/index.php"
        }
    ]
}