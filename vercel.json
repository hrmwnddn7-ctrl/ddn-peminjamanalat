{
    "version": 2,
    "cleanUrls": true,
    "functions": {
        "api/**/*.php": {
            "runtime": "vercel-php@0.7.1"
        }
    },
    "rewrites": [
        {
            "source": "/assets/(.*)",
            "destination": "/assets/$1"
        },
        {
            "source": "/login",
            "destination": "/api/login.php"
        },
        {
            "source": "/logout",
            "destination": "/api/logout.php"
        },
        {
            "source": "/(admin|peminjam|petugas)/(.*)",
            "destination": "/api/$1/$2"
        },
        {
            "source": "/(admin|peminjam|petugas)",
            "destination": "/api/$1/index.php"
        },
        {
            "source": "/",
            "destination": "/api/index.php"
        }
    ]
}