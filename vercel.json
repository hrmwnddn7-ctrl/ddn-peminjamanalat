{
    "version": 2,
    "cleanUrls": true,
    "functions": {
        "api/index.php": {
            "runtime": "vercel-php@0.7.1"
        }
    },
    "rewrites": [
        {
            "source": "/assets/(.*)",
            "destination": "/assets/$1"
        },
        {
            "source": "/(admin|peminjam|petugas)/(.*)",
            "destination": "/api/index.php"
        },
        {
            "source": "/(.*)",
            "destination": "/api/index.php"
        }
    ]
}